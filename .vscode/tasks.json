{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "lensQuery",
      "type": "promptString",
      "description": "Descreva o que voce quer fazer (ex: fix the bug in extract_symbols)"
    }
  ],
  "tasks": [
    {
      "label": "Context Lens: auto-index on open",
      "type": "shell",
      "command": "lens index --quiet && lens show map > .ctx/ctx.md 2>/dev/null || true",
      "windows": {
        "command": "lens index --quiet; New-Item -ItemType Directory -Force .ctx | Out-Null; lens show map | Out-File -Encoding utf8 .ctx/ctx.md; exit 0"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Context Lens: status",
      "type": "shell",
      "command": "lens status",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Context Lens: watch (auto-reindex)",
      "type": "shell",
      "command": "lens watch --interval 15",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Context Lens: gerar contexto para Copilot",
      "type": "shell",
      "command": "python scripts/lens-context.py \"${input:lensQuery}\" --target copilot --no-clip",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Context Lens: ChatGPT — copiar contexto",
      "type": "shell",
      "command": "python scripts/lens-context.py \"${input:lensQuery}\" --target chatgpt",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      },
      "problemMatcher": []
    }
  ]
}
