{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Context Lens: auto-index on open",
      "type": "shell",
      "command": "lens index",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Context Lens: status",
      "type": "shell",
      "command": "lens status",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Context Lens: watch (auto-reindex)",
      "type": "shell",
      "command": "lens watch --interval 15",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
