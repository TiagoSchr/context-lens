# Context Lens — index local de cada projeto (nunca commitar)
.ctx/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Testes e cobertura
.pytest_cache/
.coverage
htmlcov/

# IDEs
.vscode/settings.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# VS Code extension build artifacts
vscode-context-lens/node_modules/
vscode-context-lens/out/
*.vsix
# keep the bundled vsix inside the Python package
!src/ctx/data/context-lens.vsix
