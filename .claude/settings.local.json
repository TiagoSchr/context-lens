{
  "permissions": {
    "allow": [
      "Bash(lens *)",
      "Bash(python -m ctx.cli *)",
      "Bash(python -m ctx.scripts.hooks *)",
      "Bash(python scripts/lens-context.py *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m ctx.scripts.hooks pre-bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -m ctx.scripts.hooks post-write"
          }
        ]
      }
    ]
  }
}
